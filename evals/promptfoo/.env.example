# Copy to .env.local (gitignored) if you want to avoid typing -D flags every time.
# These are read by the promptfooconfig via {{var}} syntax when you run with --env-file or similar.

# Sovereignty: keep promptfoo fully local
PROMPTFOO_DISABLE_TELEMETRY=1

# Your current LM Studio (or other OpenAI-compat local server)
base_url=http://localhost:1234/v1
model=qwen2.5-coder-7b-instruct   # or whatever you have loaded

