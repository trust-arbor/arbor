#!/bin/sh
# Pinned mix wrapper for Arbor.
#
# Runs `mix` through the Erlang + Elixir versions pinned in `.tool-versions`
# via mise. Necessary because mise activation does not run in
# non-interactive shells, and Arbor's `arbor_orchestrator` + persistence
# code fails on the system-default OTP. See CLAUDE.md "Applied Learning":
# both Erlang AND Elixir must be pinned.
#
# Contained mode (ARBOR_MIX_CONTAINED=1):
#   Used only by Arbor.Actions.Mix for schema-bounded validation. Bypasses
#   global mise config and uses ARBOR_ERLANG_ROOT / ARBOR_ELIXIR_ROOT derived
#   by the already-loaded Arbor runtime. Ordinary developer invocations leave
#   ARBOR_MIX_CONTAINED unset and keep the mise path below.
#
# Usage (from anywhere within the repo — mise searches parent dirs for
# `.tool-versions`):
#
#     ./bin/mix test
#     ./bin/mix arbor.start
#     ./bin/mix compile --warnings-as-errors
#
# Verify the pinned versions are active:
#
#     ./bin/mix run -e 'IO.puts(System.version()); IO.puts(:erlang.system_info(:otp_release))'
#
# Bypass mise entirely (run system mix instead): just type `mix` — this
# wrapper only activates when invoked explicitly as `./bin/mix`.

set -e

if [ "${ARBOR_MIX_CONTAINED:-}" = "1" ]; then
  if [ -z "${ARBOR_ERLANG_ROOT:-}" ] || [ -z "${ARBOR_ELIXIR_ROOT:-}" ]; then
    echo "bin/mix: contained mode requires ARBOR_ERLANG_ROOT and ARBOR_ELIXIR_ROOT" >&2
    exit 127
  fi

  if [ ! -x "${ARBOR_ERLANG_ROOT}/bin/erl" ]; then
    echo "bin/mix: ARBOR_ERLANG_ROOT is not an executable Erlang root: ${ARBOR_ERLANG_ROOT}" >&2
    exit 127
  fi

  if [ ! -x "${ARBOR_ELIXIR_ROOT}/bin/mix" ]; then
    echo "bin/mix: ARBOR_ELIXIR_ROOT is not an executable Elixir root: ${ARBOR_ELIXIR_ROOT}" >&2
    exit 127
  fi

  export PATH="${ARBOR_ERLANG_ROOT}/bin:${ARBOR_ELIXIR_ROOT}/bin:${PATH:-}"
  exec "${ARBOR_ELIXIR_ROOT}/bin/mix" "$@"
fi

if ! command -v mise >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/mise" ]; then
  echo "bin/mix: mise not found in PATH or ~/.local/bin/" >&2
  echo "Install: https://mise.jdx.dev/getting-started.html" >&2
  exit 127
fi

# Prefer PATH lookup so user-installed mise shadows ~/.local/bin (e.g. brew).
MISE="$(command -v mise || echo "$HOME/.local/bin/mise")"

# `mise exec -- mix` is insufficient when the incoming PATH already has a
# system/Homebrew toolchain before mise's insertion point. This occurs in nested
# git worktrees and can silently pair the wrong Mix/OTP with the configured
# Elixir. Resolve the active project installs and put them first explicitly.
ERLANG_ROOT="$("$MISE" where erlang)"
ELIXIR_ROOT="$("$MISE" where elixir)"

export PATH="$ERLANG_ROOT/bin:$ELIXIR_ROOT/bin:$PATH"
export MIX_HOME="$ELIXIR_ROOT/.mix"
export MIX_ARCHIVES="$MIX_HOME/archives"

exec "$ELIXIR_ROOT/bin/mix" "$@"
