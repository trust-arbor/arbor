// Current-Trends Research Pipeline — Path 3 (Exa search + local LLM)
//
// Companion to current_trends.dot (Path 1: Claude CLI via ACP) and
// current_trends_brave.dot (Path 2: Brave + gemma-4-31b). This is
// Path 3: Exa's neural search with its `startCrawlDate` freshness
// control, followed by the same local gemma synthesis as Path 2.
//
// What Exa adds vs Brave for "current trends":
//   * `startCrawlDate` filter — only return pages crawled after a
//     date (Brave's `freshness=pw` is coarser; Exa lets us pin to
//     ISO 8601)
//   * `mode=auto` — Exa picks between speed and depth modes
//   * Snippet quality — Exa returns highlights from the actual
//     page text, not Brave's generic SERP snippets
//
// Writes to `~/.arbor/reports/current-trends-exa/YYYY-MM-DD.md` so
// all four paths sit side-by-side for comparison.

digraph CurrentTrendsExa {
  graph [
    goal="Produce a brief on the past week's notable activity in agent + harness engineering, from Exa search results synthesized by a local LLM",
    label="Current Trends — Exa + local LLM"
  ]

  start [shape=Mdiamond]

  // ─── Search params ──────────────────────────────────────────────────

  set_query [
    type="shell",
    command="printf '%s' 'AI coding agent harness MCP ACP tool calling new release update'",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="public"
  ]

  prep_query [
    type="transform",
    transform="identity",
    source_key="shell.set_query.output",
    output_key="query"
  ]

  // `start_crawl_date` set to seven days before today (UTC). Use the
  // shell so the date is always current — hardcoding it would make
  // the pipeline stale.
  set_start_date [
    type="shell",
    command="date -u -v-7d +%Y-%m-%d",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="public"
  ]

  prep_start_date [
    type="transform",
    transform="identity",
    source_key="shell.set_start_date.output",
    output_key="start_crawl_date"
  ]

  set_mode [
    type="shell",
    command="printf '%s' 'auto'",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="public"
  ]

  prep_mode [
    type="transform",
    transform="identity",
    source_key="shell.set_mode.output",
    output_key="mode"
  ]

  // ─── Exa search ─────────────────────────────────────────────────────

  exa_search [
    type="exec",
    target="action",
    action="exa_search",
    context_keys="query,start_crawl_date,mode"
  ]

  format_results [
    type="transform",
    transform="format",
    expression="json",
    source_key="exec.exa_search.results",
    output_key="search_results_json"
  ]

  // Build today's date into the system prompt — same fix as
  // current_trends_brave.dot / current_trends_tinyfish.dot.
  build_system_prompt [
    type="shell",
    command="cat <<EOF\nYou are a research assistant producing a weekly brief on agent + harness engineering. Today is $(date -u +%Y-%m-%d). You are given the JSON results of an Exa web search for the past week — a list of {rank, title, url, snippet, age} entries. Note: Exa returns the actual publishedDate in the 'age' field; trust it.\\n\\nOutput ONLY Markdown with this exact shape:\\n\\n# Current Trends — $(date -u +%Y-%m-%d)\\n\\n## Three headlines\\n\\n1. **<Headline>** — One to three sentences citing the source URL.\\n2. **<Headline>** — Same.\\n3. **<Headline>** — Same.\\n\\n## Releases and updates\\n\\nA bullet list of specific releases or version bumps surfaced by the search, one-line summaries, each with its source URL.\\n\\n## Patterns and shifts\\n\\n3–5 bullets about higher-level patterns visible across the results.\\n\\n## Worth a closer look\\n\\n1–3 items that didn't make the headlines but matter for Arbor specifically (capability-based security, BEAM substrate, multi-agent orchestration, harness engineering). One sentence each with URL.\\n\\nRules:\\n- Use the literal '$(date -u +%Y-%m-%d)' as the date in the title — NOT your training-cutoff date.\\n- Cite source URLs after each claim — pull them straight from the result entries. Don't invent URLs.\\n- Skip results that are obviously off-topic (general AI news, product ads, listicles, curated 'awesome-X' meta-lists).\\n- Be terse. Signal density, not coverage.\\n- Markdown only — no preamble, no code fences around the whole document, no chain-of-thought.\nEOF",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="public"
  ]

  prep_system_prompt [
    type="transform",
    transform="identity",
    source_key="shell.build_system_prompt.output",
    output_key="dynamic_system_prompt"
  ]

  // ─── Output path ────────────────────────────────────────────────────

  build_output_path [
    type="shell",
    command="mkdir -p \"$HOME/.arbor/reports/current-trends-exa\" && printf '%s' \"$HOME/.arbor/reports/current-trends-exa/$(date -u +%Y-%m-%d).md\"",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="internal"
  ]

  prep_output_path [
    type="transform",
    transform="identity",
    source_key="shell.build_output_path.output",
    output_key="path"
  ]

  // ─── Synthesis (same model + prompt shape as brave path) ────────────

  synthesize [
    type="compute",
    purpose="llm",
    simulate="false",
    llm_provider="lm_studio",
    llm_model="gemma-4-31b-it",
    use_tools="false",
    max_tokens="32768",
    temperature="0.4",
    timeout="1800000",
    system_prompt_context_key="dynamic_system_prompt",
    prompt_context_key="search_results_json"
  ]

  prep_content [
    type="transform",
    transform="identity",
    source_key="last_response",
    output_key="content"
  ]

  write_report [
    type="exec",
    target="action",
    action="file_write",
    context_keys="path,content"
  ]

  done [shape=Msquare]

  start -> set_query -> prep_query -> set_start_date -> prep_start_date -> set_mode -> prep_mode -> exa_search
  exa_search -> format_results -> build_system_prompt -> prep_system_prompt
  prep_system_prompt -> build_output_path -> prep_output_path -> synthesize
  synthesize -> prep_content -> write_report -> done
}
