// Upstream Deps Summary Pipeline
//
// LLM categorization follow-on for the upstream-deps-check pipeline.
// Reads today's `~/.arbor/reports/upstream-deps/YYYY-MM-DD.md` raw
// report and asks a local LLM (Gemma 4 31B via LM Studio by default)
// to categorize each new commit as Security / Breaking / Features /
// Cosmetic / Other, producing a one-page summary written to
// `~/.arbor/reports/upstream-deps-summary/YYYY-MM-DD.md`.
//
// Original report stays untouched — this pipeline only READS it. If
// the LLM call fails, the original is still available; this pipeline
// just produces no summary that day. The morning-digest meta-pipeline
// globs both directories, so a successful summary lands in the digest
// alongside the raw upstream-deps section.
//
// Scheduling (in :arbor_scheduler, Oban crontab):
//   {"15 6 * * *", Arbor.Scheduler.Workers.PipelineRunner,
//     args: %{"pipeline_path" =>
//       "apps/arbor_scheduler/priv/pipelines/upstream_deps_summary.dot"}}
//
// The :15 minute offset sits between upstream-deps at 06:00 and the
// morning digest at 06:30 so the summary is in place before the
// digest aggregates everything.
//
// Manual invocation:
//   Arbor.Scheduler.enqueue_pipeline(
//     "apps/arbor_scheduler/priv/pipelines/upstream_deps_summary.dot"
//   )
//
// Model choice:
//   The default `gemma-4-31b-it@q4_k_xl` is what worked well in past
//   eval rounds for structured categorization. LM Studio silently
//   serves whatever model is currently loaded (vs. Ollama which 404s
//   strictly), so swapping models is a node-attr edit. Cloud models
//   (anthropic + claude-haiku-4-5-20251001) work with a provider
//   change if you'd rather not depend on a local server.

digraph UpstreamDepsSummary {
  graph [
    goal="Categorize today's new upstream commits via LLM and write a summary report",
    label="Upstream Deps Summary"
  ]

  start [shape=Mdiamond]

  // Compute today's input report path. The shell handler captures
  // stdout as `shell.build_input_path.output`.
  // `printf '%s'` (not `echo`) — the shell handler captures stdout
  // verbatim, including a trailing newline. file_read would then try
  // to open `…/file.md\n` (with literal newline) and fail.
  build_input_path [
    type="shell",
    command="printf '%s' \"$HOME/.arbor/reports/upstream-deps/$(date -u +%Y-%m-%d).md\"",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="internal"
  ]

  // Copy the path into the well-known `path` key that the file_read
  // action consumes.
  prep_input_path [
    type="transform",
    transform="identity",
    source_key="shell.build_input_path.output",
    output_key="path"
  ]

  // Read the raw upstream-deps report. file_read returns a map with
  // :path / :content / :size, which gets flattened into
  // exec.read_report.{path,content,size} in context.
  read_report [
    type="exec",
    target="action",
    action="file_read",
    context_keys="path"
  ]

  // Run the categorization. Gemma 4 31B via LM Studio — small enough
  // to be cheap, capable enough for structured-output classification.
  // System prompt asks for terse Markdown so the summary fits in the
  // morning digest without bloating it.
  categorize [
    type="compute",
    purpose="llm",
    simulate="false",
    llm_provider="lm_studio",
    llm_model="gemma-4-31b-it",
    use_tools="false",
    // Gemma 4 31B is a reasoning model — `reasoning_content` eats
    // budget before the actual answer is emitted (~2K tokens just to
    // think). Overnight batch should give the model room to finish
    // reasoning AND produce a structured answer; 32K covers both
    // comfortably and the wall-clock cost doesn't matter at 06:15.
    // See `.arbor/roadmap/0-inbox/llm-empty-response-from-reasoning-
    // and-mtp-models.md` for the diagnosis.
    max_tokens="32768",
    temperature="0.2",
    // 30-minute timeout — overnight batch can take a while on a 31B
    // local model and we'd rather wait than ship empty.
    timeout="1800000",
    system_prompt="You categorize git commits from upstream dependency tracking. Read the markdown report below — it lists new upstream commits across several tracked repos.\n\nCRITICAL: List EVERY commit that could plausibly be a security fix or breaking change. Over-reporting is acceptable; under-reporting is NOT. If your internal reasoning flags a commit as possibly security or possibly breaking, include it. The reader will triage — your job is to surface candidates, not gate-keep.\n\nSecurity heuristics (include if ANY apply): mentions a CVE / GHSA / RUSTSEC / advisory id; bumps a dep with a security advisory; closes an auth/authz/permission bug; strips/sanitizes secrets, tokens, or sensitive data from logs/env/output; changes a default to fail-closed instead of fail-open; touches signing, encryption, capability checks, sandboxing, prompt-injection defenses, escape sequences, path-traversal protection; addresses a privacy or compliance issue.\n\nBreaking-change heuristics (include if ANY apply): says BREAKING / breaking / breaking change / API removal; removes/renames a public function, flag, or env var; changes default behavior in a way that affects existing callers; deprecates with a removal date; bumps a major version; marks a repo or module unmaintained; drops support for a version, platform, or language.\n\nOutput ONLY pure Markdown (no preamble, no code fences around the whole output) with these sections in this exact order:\n\n# Upstream Deps Summary\n\n## Categorization\n\nA bullet list giving counts: Security, Breaking, Features, Cosmetic, Other. Counts must reflect what's enumerated below — if you list 3 security commits, the count is 3, not 1. Totals add up to commits actually inspected (the report caps at 50 per repo, so a repo with 416 upstream commits shows 50).\n\n## Security commits\n\nOne bullet per security commit cited as `repo short-sha`: rationale. Cite EVERY commit your reasoning flagged. Omit this section entirely only if there are truly zero security commits across the entire input.\n\n## Breaking changes\n\nOne bullet per breaking commit cited as `repo short-sha`: rationale. Cite EVERY commit your reasoning flagged. Omit this section entirely only if there are truly zero breaking commits.\n\nBe terse, factual, no hedging. Cite specific repos and SHAs from the input — do not invent. Match the counts in `## Categorization` to the bullets you actually emit in `## Security commits` and `## Breaking changes`.",
    prompt_context_key="exec.read_report.content"
  ]

  // Compute today's output report path AND ensure the parent dir
  // exists. The shell handler captures stdout as
  // `shell.build_output_path.output` (a single line — the path).
  build_output_path [
    type="shell",
    command="mkdir -p \"$HOME/.arbor/reports/upstream-deps-summary\" && printf '%s' \"$HOME/.arbor/reports/upstream-deps-summary/$(date -u +%Y-%m-%d).md\"",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="internal"
  ]

  // Copy the output path into `path` (overriding the input path from
  // earlier, which the read step already consumed).
  prep_output_path [
    type="transform",
    transform="identity",
    source_key="shell.build_output_path.output",
    output_key="path"
  ]

  // Copy the LLM's response into `content` for file_write.
  prep_content [
    type="transform",
    transform="identity",
    source_key="last_response",
    output_key="content"
  ]

  // Write the summary. The caller's agent_id flows through as
  // session.agent_id so the write is signed and capability-checked
  // like any other action.
  write_summary [
    type="exec",
    target="action",
    action="file_write",
    context_keys="path,content"
  ]

  done [shape=Msquare]

  start -> build_input_path -> prep_input_path -> read_report -> categorize
  categorize -> build_output_path -> prep_output_path -> prep_content -> write_summary -> done
}
