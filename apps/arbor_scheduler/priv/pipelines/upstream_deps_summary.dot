// Upstream Deps Summary Pipeline
//
// LLM categorization follow-on for the upstream-deps-check pipeline.
// Reads today's `~/.arbor/reports/upstream-deps/YYYY-MM-DD.md` raw
// report and asks a local LLM (Gemma 4 31B via LM Studio by default)
// to categorize each new commit as Security / Breaking / Features /
// Cosmetic / Other, producing a one-page summary written to
// `~/.arbor/reports/upstream-deps-summary/YYYY-MM-DD.md`.
//
// Original report stays untouched — this pipeline only READS it. If
// the LLM call fails, the original is still available; this pipeline
// just produces no summary that day. The morning-digest meta-pipeline
// globs both directories, so a successful summary lands in the digest
// alongside the raw upstream-deps section.
//
// Scheduling (in :arbor_scheduler, Oban crontab):
//   {"15 6 * * *", Arbor.Scheduler.Workers.PipelineRunner,
//     args: %{"pipeline_path" =>
//       "apps/arbor_scheduler/priv/pipelines/upstream_deps_summary.dot"}}
//
// The :15 minute offset sits between upstream-deps at 06:00 and the
// morning digest at 06:30 so the summary is in place before the
// digest aggregates everything.
//
// Manual invocation:
//   Arbor.Scheduler.enqueue_pipeline(
//     "apps/arbor_scheduler/priv/pipelines/upstream_deps_summary.dot"
//   )
//
// Model choice:
//   The default `gemma-4-31b-it@q4_k_xl` is what worked well in past
//   eval rounds for structured categorization. LM Studio silently
//   serves whatever model is currently loaded (vs. Ollama which 404s
//   strictly), so swapping models is a node-attr edit. Cloud models
//   (anthropic + claude-haiku-4-5-20251001) work with a provider
//   change if you'd rather not depend on a local server.

digraph UpstreamDepsSummary {
  graph [
    goal="Categorize today's new upstream commits via LLM and write a summary report",
    label="Upstream Deps Summary"
  ]

  start [shape=Mdiamond]

  // Compute today's input report path. The shell handler captures
  // stdout as `shell.build_input_path.output`.
  build_input_path [
    type="shell",
    command="echo $HOME/.arbor/reports/upstream-deps/$(date -u +%Y-%m-%d).md",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="internal"
  ]

  // Copy the path into the well-known `path` key that the file_read
  // action consumes.
  prep_input_path [
    type="transform",
    transform="identity",
    source_key="shell.build_input_path.output",
    output_key="path"
  ]

  // Read the raw upstream-deps report. file_read returns a map with
  // :path / :content / :size, which gets flattened into
  // exec.read_report.{path,content,size} in context.
  read_report [
    type="exec",
    target="action",
    action="file_read",
    context_keys="path"
  ]

  // Run the categorization. Gemma 4 31B via LM Studio — small enough
  // to be cheap, capable enough for structured-output classification.
  // System prompt asks for terse Markdown so the summary fits in the
  // morning digest without bloating it.
  categorize [
    type="compute",
    purpose="llm",
    simulate="false",
    llm_provider="lm_studio",
    llm_model="gemma-4-31b-it@q4_k_xl",
    use_tools="false",
    max_tokens="2048",
    temperature="0.2",
    system_prompt="You categorize git commits from upstream dependency tracking. Read the markdown report below — it lists new upstream commits across several tracked repos. Output ONLY pure Markdown (no preamble, no code fences around the whole output) with these sections in order:\n\n# Upstream Deps Summary\n\n## Categorization\n\nA bullet list giving counts by category: Security, Breaking, Features, Cosmetic, Other.\n\n## Security commits\n\nOne bullet per commit citing repo + short SHA + a one-line rationale. Omit this section entirely if there are zero security commits.\n\n## Breaking changes\n\nOne bullet per commit citing repo + short SHA + a one-line rationale. Omit this section entirely if there are zero breaking commits.\n\nBe terse, factual, no hedging. Cite specific repos and SHAs from the input — do not invent.",
    prompt_context_key="exec.read_report.content"
  ]

  // Compute today's output report path AND ensure the parent dir
  // exists. The shell handler captures stdout as
  // `shell.build_output_path.output` (a single line — the path).
  build_output_path [
    type="shell",
    command="mkdir -p $HOME/.arbor/reports/upstream-deps-summary && echo $HOME/.arbor/reports/upstream-deps-summary/$(date -u +%Y-%m-%d).md",
    sandbox="none",
    timeout="5000",
    on_error="fail",
    data_class="internal"
  ]

  // Copy the output path into `path` (overriding the input path from
  // earlier, which the read step already consumed).
  prep_output_path [
    type="transform",
    transform="identity",
    source_key="shell.build_output_path.output",
    output_key="path"
  ]

  // Copy the LLM's response into `content` for file_write.
  prep_content [
    type="transform",
    transform="identity",
    source_key="last_response",
    output_key="content"
  ]

  // Write the summary. The caller's agent_id flows through as
  // session.agent_id so the write is signed and capability-checked
  // like any other action.
  write_summary [
    type="exec",
    target="action",
    action="file_write",
    context_keys="path,content"
  ]

  done [shape=Msquare]

  start -> build_input_path -> prep_input_path -> read_report -> categorize
  categorize -> build_output_path -> prep_output_path -> prep_content -> write_summary -> done
}
