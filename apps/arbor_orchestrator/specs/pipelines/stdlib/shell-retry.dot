// Shell Retry — Run a Command Until It Passes or Escalate
// Generic retry loop for shell-style operations (mix test, mix quality,
// git operations, etc.) that return an exit code. Unlike retry-escalate,
// this loop does NOT switch models between attempts — it re-runs the same
// command, optionally invoking a "fix" stage in between (e.g. a coding
// agent that reads the failure output and edits files).
//
// Context in:
//   command_target   — "action" or "shell" (default "action")
//   command_action   — action name (when target=action), e.g. "mix_test"
//   command_args     — JSON-encoded params for the action (when target=action)
//   command_shell    — full shell string (when target=shell)
//   max_retries      — maximum attempts (default "3")
//   fix_prompt       — (optional) prompt for the fix stage; if absent,
//                      a failed attempt routes directly to the next try
//
// Context out:
//   result.passed?   — final pass/fail boolean
//   result.exit_code — final exit code
//   result.stdout    — last attempt's stdout
//   result.stderr    — last attempt's stderr
//   retry.count      — total attempts made
//   retry.exhausted  — true if max retries reached without success

digraph ShellRetry {
  graph [
    goal="Run a shell command in a retry loop with optional fix-between-attempts",
    label="Shell Retry"
  ]

  start [shape=Mdiamond]

  // Initialize retry state.
  init [
    type="transform",
    prompt="Initialize: retry.count=0, retry.exhausted=false, result.passed?=false."
  ]

  // Attempt the command (either as Action or as raw shell).
  attempt [
    type="exec",
    prompt="Execute command_target with command_action (if action) or command_shell (if shell). Write result.exit_code, result.passed?, result.stdout, result.stderr from the response."
  ]

  // Check whether the attempt succeeded.
  check_success [
    type="gate",
    shape=diamond,
    predicate="expression",
    expression="result.passed?"
  ]

  // Optional: invoke a fix stage (e.g. coding agent reading stderr).
  // If fix_prompt is absent, this is a no-op transform that just bumps
  // the retry counter.
  fix_stage [
    type="compute",
    prompt="If fix_prompt is set in context, execute it with result.stdout and result.stderr available. The fix stage may edit files via tools. If fix_prompt is unset, this node is a no-op."
  ]

  // Bump retry counter, check exhaustion.
  bump_retry [
    type="transform",
    prompt="Increment retry.count. If retry.count >= max_retries, set retry.exhausted=true."
  ]

  // Check exhaustion.
  check_exhausted [
    type="gate",
    shape=diamond,
    predicate="expression",
    expression="retry.exhausted"
  ]

  done [shape=Msquare]

  // Flow
  start -> init -> attempt -> check_success
  check_success -> done [condition="context.result.passed?=true"]
  check_success -> fix_stage [condition="context.result.passed?!=true"]
  fix_stage -> bump_retry -> check_exhausted
  check_exhausted -> done [condition="context.retry.exhausted=true"]
  check_exhausted -> attempt [condition="context.retry.exhausted!=true"]
}
