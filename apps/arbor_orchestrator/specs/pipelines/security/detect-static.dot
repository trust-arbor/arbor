// Security Sentinel — static detection sub-pipeline (Phase 1).
//
// Runs the L0 static security detectors (Arbor.Eval.Suites.Security) over a
// path and records any findings (markdown + security.sentinel_finding signal).
// Reusable building block: the top-level security-assess pipeline invokes this,
// and it can also run standalone:
//
//   mix arbor.pipeline.run specs/pipelines/security/detect-static.dot
//
// The same work is available outside the engine via `mix arbor.security.scan`.

digraph security_detect_static {
  graph [
    goal="Run static security detectors over a path and record findings",
    label="Security: Detect (static)"
  ]

  start [shape=Mdiamond]

  scan [
    type="exec",
    target="action",
    action="security.run_static_detectors",
    param.path="apps"
  ]

  done [shape=Msquare]

  start -> scan
  scan -> done
}
