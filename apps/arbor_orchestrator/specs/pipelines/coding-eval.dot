// Coding Eval Pipeline
// Evaluates LLM code generation quality using compile, functional, and quality graders.
// Dataset: JSONL files with Elixir coding challenges.
// Subject: symbolic catalog name "llm" (Arbor.LLM.eval_subject/1).
//
// Business stages use registered eval_pipeline.* actions via exec target="action".
// Optional CLI/initial_values overrides (resolved relative to workdir by
// mix arbor.pipeline.eval):
//   "eval.path"        — dataset path override (leaf -> path)
//   "eval.output_path" — report output path (leaf -> output_path)
//   "eval.limit" / "eval.shuffle" / "eval.seed" — dataset controls
//
// Usage:
//   Engine.run(graph, initial_values: %{
//     "eval.path" => "priv/eval_datasets/elixir_coding.jsonl",
//     "eval.provider" => "lm_studio",
//     "eval.model" => "qwen/qwen3-coder-next"
//   }, workdir: ".")

digraph CodingEval {
  graph [
    goal="Evaluate code generation quality of an LLM model against Elixir coding challenges",
    label="Coding Eval"
  ]

  start [shape=Mdiamond]

  load_dataset [
    type="exec",
    target="action",
    action="eval_pipeline.load_dataset",
    param.path="priv/eval_datasets/elixir_coding.jsonl",
    context_keys="eval.path,eval.limit,eval.shuffle,eval.seed",
    data_class="internal"
  ]

  run_eval [
    type="exec",
    target="action",
    action="eval_pipeline.run_eval",
    param.subject="llm",
    param.graders="compile_check,functional_test,code_quality",
    context_keys="exec.load_dataset.dataset",
    data_class="internal"
  ]

  aggregate [
    type="exec",
    target="action",
    action="eval_pipeline.aggregate",
    param.metrics="accuracy,mean_score,pass_at_k",
    context_keys="exec.run_eval.results",
    data_class="internal"
  ]

  report [
    type="exec",
    target="action",
    action="eval_pipeline.report",
    param.format="markdown",
    param.output_path="eval_report.md",
    context_keys="exec.run_eval.results,exec.aggregate.metrics,eval.output_path",
    data_class="internal"
  ]

  done [shape=Msquare]

  // Flow: load dataset, run all graders in one eval pass, aggregate, report
  start -> load_dataset -> run_eval -> aggregate -> report -> done
}
