// coding-change-v1 - Canonical DOT coding workflow (Phase 1)
//
// Macro control flow for a reviewable software change. Side effects stay in
// schema-bounded Jido actions; the Engine owns branching, rework bounds,
// cleanup order, and the normalized result status.
//
// Context in (initial_values):
//   task                 - implementation task text (required)
//   repo_path            - repository root (required)
//   base_ref             - optional git base ref
//   branch_name          - optional branch name
//   worktree_base_dir    - optional worktree parent directory
//   acp_agent            - ACP provider name (required Phase 1/Phase 2 input;
//                          no graph-level default; supply e.g. "codex")
//   open_pr              - "true" | "false" (default false)
//   submit_review        - "true" | "false" (default true)
//   session.agent_id     - signing principal
//   session.task_id      - durable task id for lease/session authority
//
// Context out:
//   status               - normalized terminal status
//   legacy_status        - optional Phase 2 adapter alias (e.g.
//                          review_requires_rework when status=rework_exhausted)
//   workspace_id         - opaque workspace lease id
//   worker_session_id    - opaque ACP worker handle; retained for compatibility
//                          but no longer usable after close_worker
//   worker_provider_session_id
//                        - provider conversation ID suitable for a later
//                          authorized plan's worker.resume_session_id
//   retain_workspace     - canonical "true"/"false" plan output policy for
//                          successful workspace retention
//   branch / commit_hash - reviewable branch tip when produced
//   validation_rework_count / review_rework_count / operator_rework_count
//                        / total_rework_count
//                        - initiated same-session rework-cycle counters
//   review_cycle         - completed/next council cycle (1..3)
//   finding_ledger       - frozen JSON finding ledger from the last council cycle
//   review_disposition   - frozen ledger disposition from the last council cycle
//   prior_commit / prior_candidate_commit
//                        - prior reviewed candidate, snapshotted only after
//                          a rework budget admits another council cycle
//   delta_diff / delta_files / delta_ranges
//                        - scoped evidence since prior_commit; cumulative
//                          diff/files remain the reviewed candidate
//   rework_kind          - most recently initiated rework category
//   rework_iteration     - total initiated rework-cycle sequence
//   error                - stable terminal failure code when applicable
//   approval_request_id  - last operator approval request id (deny/rework)
//   approval_note        - bounded operator note from the last deny/rework
//
// Worker output (acp_send_message text) is advisory prose. Arbor observes the
// workspace after every successful worker turn and owns the control outcome.
//
// Resource policy: every terminal path that acquired a workspace releases it.
// No-change terminals remove; failures retain under the registry TTL;
// successful changes, PRs, and human handoffs retain only when the reviewed
// plan's retain_workspace=true. Release enforces ownership, so reused paths
// are never physically removed. Worker sessions are closed when opened; close
// success and failure both pass through exactly one cleanup-mode decision.
// Registry owner-death and cancellation cleanup move every owned worktree into
// bounded retention because an external ACP worker can outlive its owner and
// write after an inspect/remove check. Reused paths are never deletion authority.
//
// Does NOT call coding_produce_reviewable_change.
//
// Rework bound: one initiated validation repair, up to two initiated council
// repairs, and one initiated operator-approval repair, with a hard total
// maximum of two same-session repair attempts across all kinds.
// Review-budget exhaustion emits status=rework_exhausted (canonical). A
// legacy_status=review_requires_rework field is also set for Phase 2 adapters.
// Operator denial of the commit gate emits status=approval_denied (not
// pipeline_error). Operator rework steers the same worker through another
// implement/validate/commit cycle; exhausted operator rework uses
// rework_exhausted with error=operator_approval_rework_exhausted.

digraph CodingChangeV1 {
  graph [
    goal="Produce a validated, reviewed, reviewable branch via durable workspace and worker handles",
    label="Coding Change v1",
    nested_graphs="code_review_council"
  ]

  start [shape=Mdiamond]
  done  [shape=Msquare]

  // Init

  init_validation_rework_count [
    type="transform",
    transform="constant",
    expression="0",
    output_key="validation_rework_count"
  ]

  init_review_rework_count [
    type="transform",
    transform="constant",
    expression="0",
    output_key="review_rework_count"
  ]

  init_review_defaults [
    type="transform",
    transform="constant",
    expression="{\"review_cycle\":1,\"finding_ledger\":{},\"delta_diff\":\"\",\"delta_files\":[],\"delta_ranges\":{}}",
    output_key="review_defaults"
  ]

  init_finding_ledger [
    type="transform",
    transform="json_extract",
    source_key="review_defaults",
    expression="finding_ledger",
    output_key="finding_ledger"
  ]

  init_delta_diff [
    type="transform",
    transform="json_extract",
    source_key="review_defaults",
    expression="delta_diff",
    output_key="delta_diff"
  ]

  init_delta_files [
    type="transform",
    transform="json_extract",
    source_key="review_defaults",
    expression="delta_files",
    output_key="delta_files"
  ]

  init_delta_ranges [
    type="transform",
    transform="json_extract",
    source_key="review_defaults",
    expression="delta_ranges",
    output_key="delta_ranges"
  ]

  init_review_cycle [
    type="transform",
    transform="json_extract",
    source_key="review_defaults",
    expression="review_cycle",
    output_key="review_cycle"
  ]

  init_total_rework_count [
    type="transform",
    transform="constant",
    expression="0",
    output_key="total_rework_count"
  ]

  init_operator_rework_count [
    type="transform",
    transform="constant",
    expression="0",
    output_key="operator_rework_count"
  ]

  init_protocol_retry_count [
    type="transform",
    transform="constant",
    expression="0",
    output_key="protocol_retry_count"
  ]

  init_worker_send_recovery_count [
    type="transform",
    transform="constant",
    expression="0",
    output_key="worker_send_recovery_count"
  ]

  classify_profile [
    type="transform",
    transform="constant",
    expression="default",
    output_key="task_class"
  ]

  // Workspace lease

  acquire_workspace [
    type="exec",
    target="action",
    action="coding_workspace_acquire",
    context_keys="repo_path,base_ref,branch_name,worktree_base_dir,task",
    output_prefix="workspace",
    max_retries="0"
  ]

  hoist_workspace_id [
    type="transform",
    transform="identity",
    source_key="workspace.workspace_id",
    output_key="workspace_id"
  ]

  hoist_worktree_path [
    type="transform",
    transform="identity",
    source_key="workspace.worktree_path",
    output_key="worktree_path"
  ]

  hoist_branch [
    type="transform",
    transform="identity",
    source_key="workspace.branch",
    output_key="branch"
  ]

  // Worker session

  prep_cwd [
    type="transform",
    transform="identity",
    source_key="worktree_path",
    output_key="cwd"
  ]

  prep_provider [
    type="transform",
    transform="identity",
    source_key="acp_agent",
    output_key="provider"
  ]

  open_worker [
    type="exec",
    target="action",
    action="acp_start_session",
    context_keys="provider,cwd",
    param.permission_mode="default",
    param.use_pool="true",
    output_prefix="worker",
    max_retries="0"
  ]

  hoist_worker_session_id [
    type="transform",
    transform="identity",
    source_key="worker.worker_session_id",
    output_key="worker_session_id"
  ]

  hoist_worker_provider_session_id [
    type="transform",
    transform="identity",
    source_key="worker.session_id",
    output_key="worker_provider_session_id"
  ]

  // A newly minted pooled worker may not receive a provider conversation ID
  // until its first prompt. Refresh the durable continuity field after every
  // worker response while retaining the managed handle for in-run calls.
  hoist_worker_provider_session_id_from_message [
    type="transform",
    transform="identity",
    source_key="worker_msg.session_id",
    output_key="worker_provider_session_id"
  ]

  // Implement (same worker across rework)

  // Compatibility phrasing: request one terminal JSON object so resumed older
  // graph artifacts that still parse worker text do not enter protocol-repair
  // loops. The v1 graph ignores that prose for control and uses owner-observed
  // workspace state only.
  build_implement_prompt [
    type="transform",
    transform="template",
    source_key="task",
    expression="You are implementing an Arbor code change inside worktree {ctx.worktree_path}. Task: {value}. Requirements: work only in the worktree; produce a reviewable diff; do not merge, push, or open a PR. For compatibility with archived graphs, respond with ONLY one valid JSON object and no prose or Markdown: {\"status\":\"implemented\",\"summary\":\"what changed\"} or {\"status\":\"declined\",\"summary\":\"why no change was made\"}. Arbor treats this object as advisory only and decides the outcome from the owned workspace.",
    output_key="prompt"
  ]

  // Capture a bounded owner-observed fingerprint immediately before each
  // worker send so progress is relative to this turn, not only lease base.
  capture_pre_turn_workspace [
    type="exec",
    target="action",
    action="coding_workspace_inspect",
    context_keys="workspace_id",
    output_prefix="pre_turn",
    max_retries="0"
  ]

  check_pre_turn_workspace_exists [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  hoist_baseline_fingerprint [
    type="transform",
    transform="identity",
    source_key="pre_turn.fingerprint",
    output_key="baseline_fingerprint"
  ]

  // Recovery sends share the same inspect action under a distinct node so the
  // baseline is refreshed without re-entering the implement edge.
  capture_pre_turn_recovery [
    type="exec",
    target="action",
    action="coding_workspace_inspect",
    context_keys="workspace_id",
    output_prefix="pre_turn",
    max_retries="0"
  ]

  check_pre_turn_recovery_exists [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  hoist_baseline_fingerprint_recovery [
    type="transform",
    transform="identity",
    source_key="pre_turn.fingerprint",
    output_key="baseline_fingerprint"
  ]

  implement [
    type="exec",
    target="action",
    action="acp_send_message",
    context_keys="worker_session_id,prompt",
    output_prefix="worker_msg",
    max_retries="0"
  ]

  // After a successful worker turn, Arbor owns outcome authority: require an
  // explicit trusted stop_reason=end_turn, hoist the provider session id for
  // continuity, then inspect the workspace. The compatibility JSON object is
  // advisory evidence only; it never decides the pipeline outcome.

  check_worker_stop_reason [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  // One-shot send recovery. The current prompt remains in `prompt` until a
  // fresh-conversation summary deliberately replaces it.

  check_worker_send_recovery_budget [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  inc_worker_send_recovery_count [
    type="transform",
    transform="increment",
    source_key="worker_send_recovery_count",
    output_key="worker_send_recovery_count"
  ]

  acp_session_status [
    type="exec",
    target="action",
    action="acp_session_status",
    context_keys="worker_session_id",
    output_prefix="worker_status",
    max_retries="0"
  ]

  hoist_worker_provider_session_id_from_status [
    type="transform",
    transform="identity",
    source_key="worker_status.session_id",
    output_key="worker_provider_session_id"
  ]

  check_worker_status_session_id [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  check_recovery_provider_id [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  copy_worker_provider_session_id_to_session_id [
    type="transform",
    transform="identity",
    source_key="worker_provider_session_id",
    output_key="session_id"
  ]

  close_stale_worker [
    type="exec",
    target="action",
    action="acp_close_session",
    context_keys="worker_session_id",
    param.return_to_pool=false,
    output_prefix="stale_close",
    max_retries="0"
  ]

  open_recovery_worker [
    type="exec",
    target="action",
    action="acp_start_session",
    context_keys="provider,cwd,session_id",
    param.permission_mode="default",
    param.use_pool="true",
    param.fallback_to_fresh_on_resume_unavailable=true,
    output_prefix="worker",
    max_retries="0"
  ]

  hoist_recovery_worker_session_id [
    type="transform",
    transform="identity",
    source_key="worker.worker_session_id",
    output_key="worker_session_id"
  ]

  hoist_recovery_worker_provider_session_id [
    type="transform",
    transform="identity",
    source_key="worker.session_id",
    output_key="worker_provider_session_id"
  ]

  route_recovery_continuity [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  copy_recovery_pending_prompt [
    type="transform",
    transform="identity",
    source_key="prompt",
    output_key="pending_prompt"
  ]

  coding_workspace_recovery_summary [
    type="exec",
    target="action",
    action="coding_workspace_recovery_summary",
    context_keys="workspace_id,task,pending_prompt",
    output_prefix="recovery",
    max_retries="0"
  ]

  hoist_recovery_prompt [
    type="transform",
    transform="identity",
    source_key="recovery.recovery_prompt",
    output_key="prompt"
  ]

  retry_recovered_send [
    type="exec",
    target="action",
    action="acp_send_message",
    context_keys="worker_session_id,prompt,timeout,inactivity_timeout_ms",
    output_prefix="worker_msg",
    max_retries="0"
  ]

  // Inspect outcome (post-turn; compares against baseline_fingerprint)

  inspect_workspace [
    type="exec",
    target="action",
    action="coding_workspace_inspect",
    context_keys="workspace_id,baseline_fingerprint",
    output_prefix="inspect",
    max_retries="0"
  ]

  check_workspace_exists [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  hoist_dirty [
    type="transform",
    transform="identity",
    source_key="inspect.dirty",
    output_key="workspace_dirty"
  ]

  hoist_changed [
    type="transform",
    transform="identity",
    source_key="inspect.changed_from_base",
    output_key="changed_from_base"
  ]

  hoist_head_commit [
    type="transform",
    transform="identity",
    source_key="inspect.head_commit",
    output_key="head_commit"
  ]

  hoist_turn_progressed [
    type="transform",
    transform="identity",
    source_key="inspect.turn_progressed",
    output_key="turn_progressed"
  ]

  hoist_workspace_fingerprint [
    type="transform",
    transform="identity",
    source_key="inspect.fingerprint",
    output_key="workspace_fingerprint"
  ]

  route_turn_progress [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  route_no_progress [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  // Validation (top-level; ActionsExecutor owns approval wait/retry)

  prep_validation_path [
    type="transform",
    transform="identity",
    source_key="worktree_path",
    output_key="path"
  ]

  validate [
    type="exec",
    target="action",
    action="mix_compile",
    context_keys="path,workspace_id",
    param.warnings_as_errors="true",
    output_prefix="validation",
    max_retries="0"
  ]

  check_validation_passed [
    type="gate",
    shape=diamond,
    predicate="expression",
    expression="validation.passed"
  ]

  // Validation rework budget. Counters advance when a repair send is
  // initiated; transport failure can therefore leave an initiated count.

  check_validation_category_budget [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  check_validation_total_budget [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  inc_validation_rework_count [
    type="transform",
    transform="increment",
    source_key="validation_rework_count",
    output_key="validation_rework_count"
  ]

  inc_validation_total_rework_count [
    type="transform",
    transform="increment",
    source_key="total_rework_count",
    output_key="total_rework_count"
  ]

  mark_validation_rework_kind [
    type="transform",
    transform="constant",
    expression="validation",
    output_key="rework_kind"
  ]

  mark_validation_rework_iteration [
    type="transform",
    transform="identity",
    source_key="total_rework_count",
    output_key="rework_iteration"
  ]

  build_validation_rework_prompt [
    type="transform",
    transform="template",
    source_key="task",
    expression="Validation failed after your previous edit. Task: {value}. Structured validation feedback JSON: {ctx.validation.feedback_json}. Fix the issues in the same worktree. For compatibility with archived graphs, respond with ONLY one valid JSON object and no prose or Markdown: {\"status\":\"implemented\",\"summary\":\"what changed\"} or {\"status\":\"declined\",\"summary\":\"why no change was made\"}. Arbor treats this object as advisory only and decides the outcome from the owned workspace.",
    output_key="prompt"
  ]

  build_review_rework_prompt [
    type="transform",
    transform="template",
    source_key="task",
    expression="Code review requested rework. Task: {value}. Structured review feedback JSON: {ctx.review.feedback_json}. Address the review feedback in the same worktree. For compatibility with archived graphs, respond with ONLY one valid JSON object and no prose or Markdown: {\"status\":\"implemented\",\"summary\":\"what changed\"} or {\"status\":\"declined\",\"summary\":\"why no change was made\"}. Arbor treats this object as advisory only and decides the outcome from the owned workspace.",
    output_key="prompt"
  ]

  build_operator_rework_prompt [
    type="transform",
    transform="template",
    source_key="task",
    expression="Operator requested rework of the commit. Task: {value}. Operator note: {ctx.approval_note}. Address the operator feedback in the same worktree. For compatibility with archived graphs, respond with ONLY one valid JSON object and no prose or Markdown: {\"status\":\"implemented\",\"summary\":\"what changed\"} or {\"status\":\"declined\",\"summary\":\"why no change was made\"}. Arbor treats this object as advisory only and decides the outcome from the owned workspace.",
    output_key="prompt"
  ]

  // Commit / adopt HEAD

  prep_commit_path [
    type="transform",
    transform="identity",
    source_key="worktree_path",
    output_key="path"
  ]

  prep_commit_message [
    type="transform",
    transform="constant",
    expression="Coding agent change",
    output_key="message"
  ]

  // Reviewed top-level Jido action (syscall): approval decision lives here,
  // graph owns branching. Not git_commit + ExecHandler control projection.
  // head_commit binds approval to the inspected candidate revision.
  commit_change [
    type="exec",
    target="action",
    action="coding_reviewed_commit",
    context_keys="path,message,workspace_dirty,head_commit,workspace_id",
    param.all="true",
    output_prefix="commit",
    max_retries="0"
  ]

  // Branch structured commit-gate results before hoisting commit_hash.
  // coding_reviewed_commit always returns outcome=success with
  // commit.interaction_outcome set to "" (approved/unattended), denied, or rework.
  route_commit_interaction [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  hoist_commit_hash [
    type="transform",
    transform="identity",
    source_key="commit.commit_hash",
    output_key="commit_hash"
  ]

  hoist_approval_request_id [
    type="transform",
    transform="identity",
    source_key="commit.request_id",
    output_key="approval_request_id"
  ]

  hoist_approval_note [
    type="transform",
    transform="identity",
    source_key="commit.note",
    output_key="approval_note"
  ]

  mark_approval_denied_error [
    type="transform",
    transform="constant",
    expression="approval_denied",
    output_key="error"
  ]

  // Operator-approval rework budget. Shares the total rework hard cap with
  // validation and council rework; at most one initiated operator repair.

  check_operator_rework_category_budget [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  check_operator_rework_total_budget [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  inc_operator_rework_count [
    type="transform",
    transform="increment",
    source_key="operator_rework_count",
    output_key="operator_rework_count"
  ]

  inc_operator_total_rework_count [
    type="transform",
    transform="increment",
    source_key="total_rework_count",
    output_key="total_rework_count"
  ]

  mark_operator_rework_kind [
    type="transform",
    transform="constant",
    expression="operator_approval",
    output_key="rework_kind"
  ]

  mark_operator_rework_iteration [
    type="transform",
    transform="identity",
    source_key="total_rework_count",
    output_key="rework_iteration"
  ]

  mark_operator_rework_exhausted_error [
    type="transform",
    transform="constant",
    expression="operator_approval_rework_exhausted",
    output_key="error"
  ]

  legacy_status_operator_approval_rework [
    type="transform",
    transform="constant",
    expression="operator_approval_rework",
    output_key="legacy_status"
  ]

  // Clean self-commit adoption is performed inside coding_reviewed_commit
  // (workspace_dirty=false) so operator rework cannot bypass a fresh gate by
  // self-committing. There is no separate unapproved adopt_head path.

  route_after_commit [
    type="branch",
    shape=diamond
  ]

  // Committed diff + binding review
  // coding_workspace_committed_change materializes base_commit..HEAD for the
  // lease and requires HEAD to remain at the commit produced above.

  prep_expected_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="commit"
  ]

  load_committed_change [
    type="exec",
    target="action",
    action="coding_workspace_committed_change",
    context_keys="workspace_id,commit,prior_commit",
    output_prefix="change",
    max_retries="0"
  ]

  prep_review_diff [
    type="transform",
    transform="identity",
    source_key="change.diff",
    output_key="diff"
  ]

  prep_review_files [
    type="transform",
    transform="identity",
    source_key="change.files",
    output_key="files"
  ]

  prep_review_intent [
    type="transform",
    transform="identity",
    source_key="task",
    output_key="intent"
  ]

  prep_review_agent [
    type="transform",
    transform="identity",
    source_key="session.agent_id",
    output_key="agent_id"
  ]

  prep_review_base [
    type="transform",
    transform="identity",
    source_key="change.base_ref",
    output_key="base_ref"
  ]

  hoist_change_commit [
    type="transform",
    transform="identity",
    source_key="change.commit_hash",
    output_key="commit_hash"
  ]

  // Cycle 1 reviews the cumulative candidate with initialized empty delta
  // evidence. Cycles 2-3 retain that cumulative candidate and additionally
  // hoist the materialized prior_commit..HEAD delta for scoped rechecks.

  route_review_material [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  prep_review_delta_diff [
    type="transform",
    transform="identity",
    source_key="change.delta_diff",
    output_key="delta_diff"
  ]

  prep_review_delta_files [
    type="transform",
    transform="identity",
    source_key="change.delta_files",
    output_key="delta_files"
  ]

  prep_review_delta_ranges [
    type="transform",
    transform="identity",
    source_key="change.delta_ranges",
    output_key="delta_ranges"
  ]

  route_prepared_review [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  error_review_cycle_invalid [
    type="transform",
    transform="constant",
    expression="review_cycle_invalid_or_missing",
    output_key="error"
  ]

  review_change [
    type="exec",
    target="action",
    action="council_review_change",
    context_keys="diff,files,branch,base_ref,intent,agent_id,workspace_id,commit_hash,review_cycle,finding_ledger,prior_candidate_commit,delta_diff,delta_files,delta_ranges",
    output_prefix="review",
    max_retries="0"
  ]

  // Freeze every completed council cycle at top level before routing. This
  // keeps checkpoints/results self-contained and makes the next cycle consume
  // exactly the completed ledger rather than reconstructing review state.

  hoist_review_finding_ledger [
    type="transform",
    transform="identity",
    source_key="review.finding_ledger",
    output_key="finding_ledger"
  ]

  hoist_review_cycle [
    type="transform",
    transform="identity",
    source_key="review.review_cycle",
    output_key="review_cycle"
  ]

  hoist_review_disposition [
    type="transform",
    transform="identity",
    source_key="review.review_disposition",
    output_key="review_disposition"
  ]

  route_completed_review_cycle [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  route_review [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  // Dormant security-regression flow. The CodingPlan compiler removes these
  // nodes for default plans and connects them only for the reviewed profile.

  route_security_after_commit [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  // Attestation presence gates (simple single-clause conditions; no compound &&).
  // Compiler wires route_review into these; present -> validate, absent human
  // terminal / absent auto fails closed.
  route_security_attested_human [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  route_security_attested_auto [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  compare_security_rework_commit [
    type="transform",
    transform="not_equal",
    source_key="commit_hash",
    expression="prior_reviewed_commit",
    output_key="fresh_rework_commit"
  ]

  check_security_rework_fresh [
    type="gate",
    shape=diamond,
    predicate="expression",
    expression="fresh_rework_commit"
  ]

  error_security_rework_not_fresh [
    type="transform",
    transform="template",
    source_key="commit_hash",
    expression="security_rework_requires_fresh_commit: current={value}, prior={ctx.prior_reviewed_commit}",
    output_key="error"
  ]

  prep_review_validation_profile [
    type="transform",
    transform="constant",
    expression="security_regression",
    output_key="validation_profile"
  ]

  remember_validation_reviewed_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="prior_reviewed_commit"
  ]

  remember_review_reviewed_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="prior_reviewed_commit"
  ]

  // Security validation runs after council review. When that validation
  // admits rework, preserve the reviewed candidate and advance the ledger
  // cycle before returning feedback to the worker.

  snapshot_validation_prior_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="prior_commit"
  ]

  snapshot_validation_prior_candidate_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="prior_candidate_commit"
  ]

  inc_validation_review_cycle [
    type="transform",
    transform="increment",
    source_key="review_cycle",
    output_key="review_cycle"
  ]

  hoist_review_attestation_id [
    type="transform",
    transform="identity",
    source_key="review.review_attestation_id",
    output_key="review_attestation_id"
  ]

  post_validation_expected_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="commit"
  ]

  post_validation_committed_change [
    type="exec",
    target="action",
    action="coding_workspace_committed_change",
    context_keys="workspace_id,commit",
    output_prefix="post_validation_change",
    max_retries="0"
  ]

  error_post_validation_committed_change [
    type="transform",
    transform="constant",
    expression="post_validation_committed_change_failed",
    output_key="error"
  ]

  route_validated_review [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  // Council rework budget. Like validation, counters represent initiated
  // same-session repair sends rather than denied/exhausted attempts.

  check_review_category_budget [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  check_review_total_budget [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  inc_review_rework_count [
    type="transform",
    transform="increment",
    source_key="review_rework_count",
    output_key="review_rework_count"
  ]

  snapshot_review_prior_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="prior_commit"
  ]

  snapshot_review_prior_candidate_commit [
    type="transform",
    transform="identity",
    source_key="commit_hash",
    output_key="prior_candidate_commit"
  ]

  inc_review_cycle [
    type="transform",
    transform="increment",
    source_key="review_cycle",
    output_key="review_cycle"
  ]

  inc_review_total_rework_count [
    type="transform",
    transform="increment",
    source_key="total_rework_count",
    output_key="total_rework_count"
  ]

  mark_review_rework_kind [
    type="transform",
    transform="constant",
    expression="review",
    output_key="rework_kind"
  ]

  mark_review_rework_iteration [
    type="transform",
    transform="identity",
    source_key="total_rework_count",
    output_key="rework_iteration"
  ]

  // Optional draft PR

  route_publish [
    type="branch",
    shape=diamond
  ]

  prep_pr_path [
    type="transform",
    transform="identity",
    source_key="worktree_path",
    output_key="path"
  ]

  prep_pr_title [
    type="transform",
    transform="template",
    source_key="task",
    expression="Coding agent: {value}",
    output_key="title"
  ]

  open_draft_pr [
    type="exec",
    target="action",
    action="git_pr",
    context_keys="path,branch,title",
    param.draft="true",
    output_prefix="pr",
    max_retries="0"
  ]

  // Terminal status markers

  status_no_changes [
    type="transform",
    transform="constant",
    expression="no_changes",
    output_key="status"
  ]

  status_validation_failed [
    type="transform",
    transform="constant",
    expression="validation_failed",
    output_key="status"
  ]

  status_rework_exhausted [
    type="transform",
    transform="constant",
    expression="rework_exhausted",
    output_key="status"
  ]

  status_approval_denied [
    type="transform",
    transform="constant",
    expression="approval_denied",
    output_key="status"
  ]

  // Phase 2 adapter alias; not production routing policy
  legacy_status_review_requires_rework [
    type="transform",
    transform="constant",
    expression="review_requires_rework",
    output_key="legacy_status"
  ]

  status_review_rejected [
    type="transform",
    transform="constant",
    expression="review_rejected",
    output_key="status"
  ]

  status_review_failed [
    type="transform",
    transform="constant",
    expression="review_failed",
    output_key="status"
  ]

  status_human_review_required [
    type="transform",
    transform="constant",
    expression="human_review_required",
    output_key="status"
  ]

  status_pr_failed [
    type="transform",
    transform="constant",
    expression="pr_failed",
    output_key="status"
  ]

  status_pr_created [
    type="transform",
    transform="constant",
    expression="pr_created",
    output_key="status"
  ]

  status_change_committed [
    type="transform",
    transform="constant",
    expression="change_committed",
    output_key="status"
  ]

  status_pipeline_error [
    type="transform",
    transform="constant",
    expression="pipeline_error",
    output_key="status"
  ]

  // Same status as pipeline_error, but routes through worker/workspace cleanup
  status_pipeline_error_then_close [
    type="transform",
    transform="constant",
    expression="pipeline_error",
    output_key="status"
  ]

  // Failed-node details remain in the Engine outcome audit. These normalized
  // codes use the existing terminal `error` context convention so callers get
  // a stable, JSON-clean reason after cleanup completes.

  error_committed_change_materialization [
    type="transform",
    transform="constant",
    expression="committed_change_materialization_failed",
    output_key="error"
  ]

  error_council_review [
    type="transform",
    transform="constant",
    expression="council_review_failed",
    output_key="error"
  ]

  error_review_tier_invalid [
    type="transform",
    transform="constant",
    expression="review_tier_invalid_or_missing",
    output_key="error"
  ]

  error_draft_pr [
    type="transform",
    transform="constant",
    expression="draft_pr_failed",
    output_key="error"
  ]

  error_worker_stop_reason_not_end_turn [
    type="transform",
    transform="constant",
    expression="worker_stop_reason_not_end_turn",
    output_key="error"
  ]

  error_workspace_missing [
    type="transform",
    transform="constant",
    expression="workspace_missing",
    output_key="error"
  ]

  error_worker_turn_no_progress [
    type="transform",
    transform="constant",
    expression="worker_turn_no_progress",
    output_key="error"
  ]

  error_worker_send_recovery_exhausted [
    type="transform",
    transform="constant",
    expression="worker_send_recovery_exhausted",
    output_key="error"
  ]

  error_worker_provider_session_missing [
    type="transform",
    transform="constant",
    expression="worker_provider_session_id_missing",
    output_key="error"
  ]

  error_worker_stale_close_failed [
    type="transform",
    transform="constant",
    expression="worker_stale_close_failed",
    output_key="error"
  ]

  error_worker_recovery_reopen_failed [
    type="transform",
    transform="constant",
    expression="worker_recovery_reopen_failed",
    output_key="error"
  ]

  error_worker_recovery_continuity_invalid [
    type="transform",
    transform="constant",
    expression="worker_recovery_continuity_invalid",
    output_key="error"
  ]

  error_worker_recovery_summary_failed [
    type="transform",
    transform="constant",
    expression="worker_recovery_summary_failed",
    output_key="error"
  ]

  error_worker_recovery_send_failed [
    type="transform",
    transform="constant",
    expression="worker_recovery_send_failed",
    output_key="error"
  ]

  // Cleanup

  close_worker [
    type="exec",
    target="action",
    action="acp_close_session",
    context_keys="worker_session_id",
    param.return_to_pool=true,
    output_prefix="close",
    max_retries="0"
  ]

  route_release_mode [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  route_success_workspace_retention [
    type="branch",
    shape=diamond,
    fan_out="false"
  ]

  prep_release_mode_retain [
    type="transform",
    transform="constant",
    expression="retain",
    output_key="mode"
  ]

  prep_release_mode_remove [
    type="transform",
    transform="constant",
    expression="remove",
    output_key="mode"
  ]

  release_workspace [
    type="exec",
    target="action",
    action="coding_workspace_release",
    context_keys="workspace_id,mode",
    output_prefix="release",
    max_retries="0"
  ]

  // Release without close (worker never opened). This is a failure terminal,
  // so preserve the invocation-owned worktree for the registry TTL.
  prep_release_mode_only [
    type="transform",
    transform="constant",
    expression="retain",
    output_key="mode"
  ]

  release_workspace_only [
    type="exec",
    target="action",
    action="coding_workspace_release",
    context_keys="workspace_id,mode",
    output_prefix="release",
    max_retries="0"
  ]

  // Flow

  start -> init_validation_rework_count -> init_review_rework_count
  init_review_rework_count -> init_review_defaults -> init_finding_ledger
  init_finding_ledger -> init_delta_diff -> init_delta_files -> init_delta_ranges
  init_delta_ranges -> init_review_cycle -> init_operator_rework_count
  init_operator_rework_count -> init_total_rework_count -> init_protocol_retry_count
  init_protocol_retry_count -> init_worker_send_recovery_count
  init_worker_send_recovery_count -> classify_profile -> acquire_workspace

  // Acquire failure: no lease held
  acquire_workspace -> status_pipeline_error [condition="outcome=fail"]
  status_pipeline_error -> done

  acquire_workspace -> hoist_workspace_id [condition="outcome=success"]
  hoist_workspace_id -> hoist_worktree_path -> hoist_branch
  hoist_branch -> prep_cwd -> prep_provider -> open_worker

  // Worker open failure: release workspace, no close
  open_worker -> prep_release_mode_only [condition="outcome=fail"]
  prep_release_mode_only -> release_workspace_only -> status_pipeline_error

  open_worker -> hoist_worker_session_id [condition="outcome=success"]
  hoist_worker_session_id -> hoist_worker_provider_session_id
  hoist_worker_provider_session_id -> build_implement_prompt
  build_implement_prompt -> capture_pre_turn_workspace
  capture_pre_turn_workspace -> status_pipeline_error_then_close [condition="outcome=fail"]
  capture_pre_turn_workspace -> check_pre_turn_workspace_exists [condition="outcome=success"]
  check_pre_turn_workspace_exists -> error_workspace_missing [condition="context.pre_turn.exists!=true"]
  check_pre_turn_workspace_exists -> hoist_baseline_fingerprint [condition="context.pre_turn.exists=true"]
  hoist_baseline_fingerprint -> implement

  // Worker send sites use one engine-attempt and converge on one recovery gate.
  implement -> check_worker_send_recovery_budget [condition="outcome=fail"]
  check_worker_send_recovery_budget -> error_worker_send_recovery_exhausted [condition="context.worker_send_recovery_count>=1"]
  check_worker_send_recovery_budget -> inc_worker_send_recovery_count [condition="context.worker_send_recovery_count<1"]
  inc_worker_send_recovery_count -> acp_session_status
  acp_session_status -> check_worker_status_session_id [condition="outcome=success"]
  acp_session_status -> check_recovery_provider_id [condition="outcome=fail"]
  check_worker_status_session_id -> hoist_worker_provider_session_id_from_status [condition="context.worker_status.session_id!=\"\""]
  check_worker_status_session_id -> check_recovery_provider_id
  hoist_worker_provider_session_id_from_status -> check_recovery_provider_id
  check_recovery_provider_id -> copy_worker_provider_session_id_to_session_id [condition="context.worker_provider_session_id!=\"\""]
  check_recovery_provider_id -> error_worker_provider_session_missing
  copy_worker_provider_session_id_to_session_id -> close_stale_worker
  close_stale_worker -> open_recovery_worker [condition="outcome=success"]
  close_stale_worker -> error_worker_stale_close_failed [condition="outcome=fail"]
  open_recovery_worker -> hoist_recovery_worker_session_id [condition="outcome=success"]
  open_recovery_worker -> error_worker_recovery_reopen_failed [condition="outcome=fail"]
  hoist_recovery_worker_session_id -> hoist_recovery_worker_provider_session_id
  hoist_recovery_worker_provider_session_id -> route_recovery_continuity
  // Re-fingerprint before every recovered send so progress is relative to the
  // state immediately before that turn, not a stale pre-failure baseline.
  route_recovery_continuity -> capture_pre_turn_recovery [condition="context.worker.continuity=resumed"]
  route_recovery_continuity -> copy_recovery_pending_prompt [condition="context.worker.continuity=fresh_recovery"]
  route_recovery_continuity -> error_worker_recovery_continuity_invalid
  copy_recovery_pending_prompt -> coding_workspace_recovery_summary
  coding_workspace_recovery_summary -> error_worker_recovery_summary_failed [condition="outcome=fail"]
  coding_workspace_recovery_summary -> hoist_recovery_prompt [condition="outcome=success"]
  hoist_recovery_prompt -> capture_pre_turn_recovery
  capture_pre_turn_recovery -> status_pipeline_error_then_close [condition="outcome=fail"]
  capture_pre_turn_recovery -> check_pre_turn_recovery_exists [condition="outcome=success"]
  check_pre_turn_recovery_exists -> error_workspace_missing [condition="context.pre_turn.exists!=true"]
  check_pre_turn_recovery_exists -> hoist_baseline_fingerprint_recovery [condition="context.pre_turn.exists=true"]
  hoist_baseline_fingerprint_recovery -> retry_recovered_send
  retry_recovered_send -> error_worker_recovery_send_failed [condition="outcome=fail"]
  retry_recovered_send -> hoist_worker_provider_session_id_from_message [condition="outcome=success"]

  // Every recovery terminal uses the existing close/release tail.
  error_worker_send_recovery_exhausted -> status_pipeline_error_then_close
  error_worker_provider_session_missing -> status_pipeline_error_then_close
  error_worker_stale_close_failed -> status_pipeline_error_then_close
  error_worker_recovery_reopen_failed -> status_pipeline_error_then_close
  error_worker_recovery_continuity_invalid -> status_pipeline_error_then_close
  error_worker_recovery_summary_failed -> status_pipeline_error_then_close
  error_worker_recovery_send_failed -> status_pipeline_error_then_close
  error_worker_stop_reason_not_end_turn -> status_pipeline_error_then_close
  error_workspace_missing -> status_pipeline_error_then_close
  error_worker_turn_no_progress -> status_pipeline_error_then_close
  status_pipeline_error_then_close -> close_worker

  // Owner-observed outcome: successful turns require trusted end_turn, then
  // inspect the workspace. Worker prose never gates validation/review/commit
  // vs no_changes.
  implement -> hoist_worker_provider_session_id_from_message [condition="outcome=success"]
  hoist_worker_provider_session_id_from_message -> check_worker_stop_reason
  check_worker_stop_reason -> inspect_workspace [condition="context.worker_msg.stop_reason=end_turn"]
  check_worker_stop_reason -> error_worker_stop_reason_not_end_turn

  // Impossible seed edges keep the reviewed dormant subgraph structurally
  // reachable. The compiler removes them before activating the security profile;
  // default compilation drops them with the dormant nodes.
  start -> route_security_after_commit [condition="0=1"]
  start -> prep_review_validation_profile [condition="0=1"]
  start -> remember_validation_reviewed_commit [condition="0=1"]
  start -> remember_review_reviewed_commit [condition="0=1"]
  start -> hoist_review_attestation_id [condition="0=1"]
  start -> post_validation_expected_commit [condition="0=1"]
  start -> route_security_attested_human [condition="0=1"]
  start -> route_security_attested_auto [condition="0=1"]
  start -> snapshot_validation_prior_commit [condition="0=1"]

  // Dormant security-regression edges retain default behavior until the
  // compiler connects the reviewed profile-specific entry points.
  route_security_after_commit -> route_after_commit [condition="context.total_rework_count=0"]
  route_security_after_commit -> compare_security_rework_commit [condition="context.total_rework_count>0"]
  compare_security_rework_commit -> check_security_rework_fresh
  check_security_rework_fresh -> route_after_commit [condition="outcome=success"]
  check_security_rework_fresh -> error_security_rework_not_fresh [condition="outcome=fail"]
  error_security_rework_not_fresh -> status_validation_failed
  prep_review_validation_profile -> review_change
  snapshot_validation_prior_commit -> snapshot_validation_prior_candidate_commit
  snapshot_validation_prior_candidate_commit -> inc_validation_review_cycle
  inc_validation_review_cycle -> inc_validation_rework_count
  remember_validation_reviewed_commit -> check_validation_category_budget
  remember_review_reviewed_commit -> check_review_category_budget
  route_security_attested_human -> hoist_review_attestation_id [condition="context.review.review_attestation_id!=\"\""]
  route_security_attested_human -> status_human_review_required [condition="context.review.review_attestation_id=\"\""]
  route_security_attested_auto -> hoist_review_attestation_id [condition="context.review.review_attestation_id!=\"\""]
  // Intentional fallback: missing auto-proceed authority must fail closed.
  route_security_attested_auto -> error_review_tier_invalid
  hoist_review_attestation_id -> validate
  post_validation_expected_commit -> post_validation_committed_change
  post_validation_committed_change -> error_post_validation_committed_change [condition="outcome=fail"]
  error_post_validation_committed_change -> status_validation_failed
  post_validation_committed_change -> route_validated_review [condition="outcome=success"]
  route_validated_review -> route_human_review [condition="context.review.tier_decision=human_review"]
  route_validated_review -> route_publish [condition="context.review.tier_decision=auto_proceed"]
  route_validated_review -> error_review_tier_invalid

  // Owner-observed workspace inspection is the control authority after every
  // successful worker turn (initial, recovery, and rework).
  inspect_workspace -> status_pipeline_error_then_close [condition="outcome=fail"]
  inspect_workspace -> check_workspace_exists [condition="outcome=success"]
  // Missing worktree is a pipeline error with retention — never no_changes.
  check_workspace_exists -> error_workspace_missing [condition="context.inspect.exists!=true"]
  check_workspace_exists -> hoist_dirty [condition="context.inspect.exists=true"]
  hoist_dirty -> hoist_changed -> hoist_head_commit
  hoist_head_commit -> hoist_turn_progressed -> hoist_workspace_fingerprint
  hoist_workspace_fingerprint -> route_turn_progress

  // Per-turn progress: initial no-op => no_changes; rework no-op => pipeline_error
  // so a prior candidate is never re-presented as fresh work.
  route_turn_progress -> prep_validation_path [condition="context.turn_progressed=true"]
  route_turn_progress -> route_no_progress [condition="context.turn_progressed!=true"]
  route_no_progress -> error_worker_turn_no_progress [condition="context.total_rework_count>=1"]
  route_no_progress -> status_no_changes [condition="context.total_rework_count<1"]
  status_no_changes -> close_worker

  // Progress this turn -> validate
  prep_validation_path -> validate

  // Hard validation action error (not soft passed=false)
  validate -> status_validation_failed [condition="outcome=fail"]
  validate -> check_validation_passed [condition="outcome=success"]

  // Validation soft-fail: initiate at most one validation repair and never a
  // third total repair attempt.
  check_validation_passed -> check_validation_category_budget [condition="outcome=fail"]
  check_validation_category_budget -> status_validation_failed [condition="context.validation_rework_count>=1"]
  check_validation_category_budget -> check_validation_total_budget [condition="context.validation_rework_count<1"]
  check_validation_total_budget -> status_validation_failed [condition="context.total_rework_count>=2"]
  check_validation_total_budget -> inc_validation_rework_count [condition="context.total_rework_count<2"]
  status_validation_failed -> close_worker
  inc_validation_rework_count -> inc_validation_total_rework_count
  inc_validation_total_rework_count -> mark_validation_rework_kind
  mark_validation_rework_kind -> mark_validation_rework_iteration
  mark_validation_rework_iteration -> build_validation_rework_prompt
  build_validation_rework_prompt -> capture_pre_turn_workspace

  // Validation passed -> commit or adopt HEAD
  check_validation_passed -> prep_commit_path [condition="outcome=success"]
  prep_commit_path -> prep_commit_message

  // Always route through the reviewed commit/adoption gate so a self-commit
  // after operator rework (clean worktree) cannot bypass fresh approval.
  prep_commit_message -> commit_change
  commit_change -> status_pipeline_error_then_close [condition="outcome=fail"]
  commit_change -> route_commit_interaction [condition="outcome=success"]

  // Normal approved/unattended result (empty interaction_outcome).
  route_commit_interaction -> hoist_commit_hash [condition="context.commit.interaction_outcome=\"\""]

  // Operator denied the commit gate: terminal approval_denied + cleanup.
  route_commit_interaction -> hoist_approval_request_id [condition="context.commit.interaction_outcome=denied"]
  hoist_approval_request_id -> hoist_approval_note
  hoist_approval_note -> mark_approval_denied_error -> status_approval_denied
  status_approval_denied -> close_worker

  // Operator rework: shared total budget + one operator category cycle, then
  // the same worker receives a new implement turn (fresh commit approval later).
  route_commit_interaction -> hoist_approval_request_id_rework [condition="context.commit.interaction_outcome=rework"]

  hoist_approval_request_id_rework [
    type="transform",
    transform="identity",
    source_key="commit.request_id",
    output_key="approval_request_id"
  ]

  hoist_approval_note_rework [
    type="transform",
    transform="identity",
    source_key="commit.note",
    output_key="approval_note"
  ]

  hoist_approval_request_id_rework -> hoist_approval_note_rework
  hoist_approval_note_rework -> check_operator_rework_category_budget

  check_operator_rework_category_budget -> legacy_status_operator_approval_rework [condition="context.operator_rework_count>=1"]
  check_operator_rework_category_budget -> check_operator_rework_total_budget [condition="context.operator_rework_count<1"]
  check_operator_rework_total_budget -> legacy_status_operator_approval_rework [condition="context.total_rework_count>=2"]
  check_operator_rework_total_budget -> inc_operator_rework_count [condition="context.total_rework_count<2"]

  legacy_status_operator_approval_rework -> mark_operator_rework_exhausted_error
  mark_operator_rework_exhausted_error -> status_rework_exhausted

  inc_operator_rework_count -> inc_operator_total_rework_count
  inc_operator_total_rework_count -> mark_operator_rework_kind
  mark_operator_rework_kind -> mark_operator_rework_iteration
  mark_operator_rework_iteration -> build_operator_rework_prompt
  build_operator_rework_prompt -> capture_pre_turn_workspace

  // Unknown interaction_outcome fails closed (not success, not silent deny).
  route_commit_interaction -> status_pipeline_error_then_close

  hoist_commit_hash -> route_after_commit

  // Skip review when submit_review=false
  route_after_commit -> route_publish [condition="context.submit_review=false"]
  route_after_commit -> prep_expected_commit [condition="context.submit_review!=false"]
  prep_expected_commit -> load_committed_change

  // Committed review-material failure
  load_committed_change -> error_committed_change_materialization [condition="outcome=fail"]
  error_committed_change_materialization -> status_review_failed
  load_committed_change -> hoist_change_commit [condition="outcome=success"]
  hoist_change_commit -> prep_review_diff
  prep_review_diff -> prep_review_files -> prep_review_intent -> prep_review_agent -> prep_review_base
  prep_review_base -> route_review_material

  // Only canonical cycles are reviewable. Cycle 1 uses the initialized empty
  // delta values; cycles 2-3 must traverse the materialized delta hoists.
  route_review_material -> route_prepared_review [condition="context.review_cycle=1"]
  route_review_material -> prep_review_delta_diff [condition="context.review_cycle=2"]
  route_review_material -> prep_review_delta_diff [condition="context.review_cycle=3"]
  route_review_material -> error_review_cycle_invalid
  prep_review_delta_diff -> prep_review_delta_files -> prep_review_delta_ranges
  prep_review_delta_ranges -> route_prepared_review
  route_prepared_review -> review_change
  error_review_cycle_invalid -> status_review_failed

  review_change -> error_council_review [condition="outcome=fail"]
  error_council_review -> status_review_failed
  status_review_failed -> close_worker

  review_change -> hoist_review_finding_ledger [condition="outcome=success"]
  hoist_review_finding_ledger -> hoist_review_cycle -> hoist_review_disposition
  hoist_review_disposition -> route_completed_review_cycle
  route_completed_review_cycle -> route_review [condition="context.review_cycle=1"]
  route_completed_review_cycle -> route_review [condition="context.review_cycle=2"]
  route_completed_review_cycle -> route_review [condition="context.review_cycle=3"]
  route_completed_review_cycle -> error_review_cycle_invalid

  // Review routing by tier_decision
  route_review -> check_review_category_budget [condition="context.review.tier_decision=rework"]
  route_review -> status_review_rejected [condition="context.review.tier_decision=stop"]
  route_review -> route_human_review [condition="context.review.tier_decision=human_review"]
  route_review -> route_publish [condition="context.review.tier_decision=auto_proceed"]
  route_review -> error_review_tier_invalid
  error_review_tier_invalid -> status_review_failed

  status_review_rejected -> close_worker

  // Human review: optional PR else human_review_required
  route_human_review [
    type="branch",
    shape=diamond
  ]

  route_human_review -> status_human_review_required [condition="context.open_pr!=true"]
  status_human_review_required -> close_worker
  route_human_review -> prep_pr_path [condition="context.open_pr=true"]

  // Review repair admits up to two council cycles while retaining the shared
  // hard total of two initiated repair attempts across all categories.
  check_review_category_budget -> legacy_status_review_requires_rework [condition="context.review_rework_count>=2"]
  check_review_category_budget -> check_review_total_budget [condition="context.review_rework_count<2"]
  check_review_total_budget -> legacy_status_review_requires_rework [condition="context.total_rework_count>=2"]
  check_review_total_budget -> snapshot_review_prior_commit [condition="context.total_rework_count<2"]

  // Exhausted: canonical rework_exhausted + legacy_status for Phase 2 adapters
  legacy_status_review_requires_rework -> status_rework_exhausted
  status_rework_exhausted -> close_worker
  snapshot_review_prior_commit -> snapshot_review_prior_candidate_commit
  snapshot_review_prior_candidate_commit -> inc_review_cycle
  inc_review_cycle -> inc_review_rework_count
  inc_review_rework_count -> inc_review_total_rework_count
  inc_review_total_rework_count -> mark_review_rework_kind
  mark_review_rework_kind -> mark_review_rework_iteration
  mark_review_rework_iteration -> build_review_rework_prompt
  build_review_rework_prompt -> capture_pre_turn_workspace

  // Publish: optional draft PR
  route_publish -> prep_pr_path [condition="context.open_pr=true"]
  route_publish -> status_change_committed [condition="context.open_pr!=true"]
  status_change_committed -> close_worker

  prep_pr_path -> prep_pr_title -> open_draft_pr
  open_draft_pr -> error_draft_pr [condition="outcome=fail"]
  error_draft_pr -> status_pr_failed
  status_pr_failed -> close_worker
  open_draft_pr -> status_pr_created [condition="outcome=success"]
  status_pr_created -> close_worker

  // Shared cleanup tail (worker opened): close may fail; both outcomes make
  // one deterministic decision. Retain on failures, remove aborted/no-change
  // work, and let the reviewed plan decide successful handoff/publication.
  close_worker -> route_release_mode [condition="outcome=success"]
  close_worker -> route_release_mode [condition="outcome=fail"]

  route_release_mode -> prep_release_mode_remove [condition="context.status=declined"]
  route_release_mode -> prep_release_mode_remove [condition="context.status=no_changes"]

  route_release_mode -> prep_release_mode_retain [condition="context.status=validation_failed"]
  route_release_mode -> prep_release_mode_retain [condition="context.status=rework_exhausted"]
  route_release_mode -> prep_release_mode_retain [condition="context.status=approval_denied"]
  route_release_mode -> prep_release_mode_retain [condition="context.status=review_rejected"]
  route_release_mode -> prep_release_mode_retain [condition="context.status=review_failed"]
  route_release_mode -> prep_release_mode_retain [condition="context.status=pr_failed"]
  route_release_mode -> prep_release_mode_retain [condition="context.status=pipeline_error"]

  route_release_mode -> route_success_workspace_retention [condition="context.status=change_committed"]
  route_release_mode -> route_success_workspace_retention [condition="context.status=pr_created"]
  route_release_mode -> route_success_workspace_retention [condition="context.status=human_review_required"]

  // Unknown terminal statuses fail closed to bounded retention rather than
  // dead-ending before release.
  route_release_mode -> prep_release_mode_retain

  route_success_workspace_retention -> prep_release_mode_retain [condition="context.retain_workspace=true"]
  route_success_workspace_retention -> prep_release_mode_remove [condition="context.retain_workspace=false"]

  // A malformed or absent plan value also retains; compiler-attested plans
  // always provide canonical true/false strings.
  route_success_workspace_retention -> prep_release_mode_retain

  prep_release_mode_retain -> release_workspace -> done
  prep_release_mode_remove -> release_workspace
}
